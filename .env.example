# ═══════════════════════════════════════════════════════════════
#  ITsGOLU UPLOADER — Environment Variables Template
#  Copy this file to .env and fill in your values
#  DO NOT commit .env to git!
# ═══════════════════════════════════════════════════════════════

# ─── Telegram API ─────────────────────────────────────────────
API_ID=your_api_id_here
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# ─── Owner & Admins ───────────────────────────────────────────
OWNER_ID=your_telegram_id_here
ADMINS=id1 id2 id3

# ─── MongoDB Atlas ────────────────────────────────────────────
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
DATABASE_NAME=ITsGOLU_db

# ─── Bot Settings ─────────────────────────────────────────────
CREDIT=ITsGOLU
THUMBNAILS=

# ─── Web Server (Render/Koyeb need this for health checks) ────
PORT=8000
WEB_SERVER=true
